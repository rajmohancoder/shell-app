{
  "name": "shell-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "install:all": "node scripts/install.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@rajmohancoder/api-client": "workspace:^",
    "@rajmohancoder/auth-sdk": "workspace:^",
    "@rajmohancoder/events": "workspace:^",
    "@rajmohancoder/types": "workspace:^",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.3.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "@types/node": "^26.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
